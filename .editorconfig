# ─── ASSASIN AntiCheat v1.0.0 ────────────────────────────────────────────────
# Author: TyouDm
# EditorConfig: https://editorconfig.org
root = true

# ─── All files ───────────────────────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true

# ─── Java ────────────────────────────────────────────────────────────────────
[*.java]
indent_style = space
indent_size  = 4
max_line_length = 120

# ─── Kotlin (Gradle DSL) ─────────────────────────────────────────────────────
[*.{kt,kts}]
indent_style = space
indent_size  = 4
max_line_length = 120

# ─── YAML (configs) ──────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_style = space
indent_size  = 2

# ─── JSON ────────────────────────────────────────────────────────────────────
[*.json]
indent_style = space
indent_size  = 2

# ─── Markdown ────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length          = off

# ─── Gradle wrapper properties ───────────────────────────────────────────────
[gradle-wrapper.properties]
indent_style = space
indent_size  = 4
